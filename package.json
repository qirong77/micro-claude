{
    "name": "micro-claude",
    "private": true,
    "scripts": {
        "dev": "bun run src/index.ts",
        "build": "esbuild ./src/index.ts --bundle --platform=node --target=node18 --banner:js='#!/usr/bin/env node' --outfile=./dist/bin/index.cjs",
        "postbuild": "npm i -g",
        "test": "vitest run"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.95.0",
        "@types/node": "^25.6.2",
        "dotenv": "^17.4.2",
        "esbuild": "^0.28.0",
        "glob": "^13.0.6"
    },
    "bin": {
        "mica": "dist/bin/index.cjs"
    },
    "devDependencies": {
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^3.2.4"
    }
}
